---
permalink: /bookmarks/index.html
---
{% extends 'layouts/base.njk' %}

{% block head %}
	<title>{{ bookmark.title }} · Aphroconfuso</title>
	<meta content="{{ contributor.metaDescription or metadata.description }}" name="description">
	<meta property="og:image" content="{{ metadata.settings.socialImage }}">
{% endblock %}

{% block content %}
	<article class="generic">
		<header>
			<h3>&nbsp;</h5>
			<h1>{{ bookmark.title }}</h1>
			<h2>&nbsp;</h2>
		</header>
		<div class="container">
			<section id="grid-max-panel-left-top">
				<!-- -->
			</section>
			<section id="grid-max-panel-right-top">
				<!-- X -->
			</section>
			<section id="grid-body">
				<div class="generic-body-text">{{ bookmark.body | prettifyMaltese | safe }}</div>
				<section id="bookmarks">
					<ol></ol>
					<template>
						<li>
						<header>
							<h3>template</h3>
							<h1></h1>
							<h2><h2>
						</header>
						<div class="body-text"></div>
						</li>
					</template>
				</section>
			</section>
			<section id="grid-max-panel-left-bottom">
				<!-- X -->
			</section>
			<section id="grid-max-panel-right-bottom">
				<!-- X -->
			</section>
		</div>
	</article>
{% endblock %}
